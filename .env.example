# Port for the local server (optional; defaults to 3000).
PORT=3000

# --- contact_me email notification (Resend) ---
# Leave unset to run in dry-run mode: contact_me logs the message instead of sending.
# RESEND_API_KEY=re_xxxxxxxx
# CONTACT_TO_EMAIL=you@example.com
# Optional sender. Defaults to Resend's test address (delivers to your account email).
# Verify a domain in Resend to send from your own address in production.
# CONTACT_FROM_EMAIL="Your Name <hello@yourdomain.com>"

# --- rate limiting (Upstash Redis, serverless) ---
# Without these, the serverless rate limiter is a no-op. Connect Upstash via the
# Vercel Marketplace (free tier) and it sets these automatically; then redeploy.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
